{
  "name": "nodejs-express-starter",
  "version": "0.0.1",
  "description": "Modern Express.js starter template with TypeScript, logging and scalable architecture.",
  "main": "dist/app.js",
  "type": "module",

  "scripts": {
    "dev": "tsx watch --env-file=.env src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",

    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",

    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },

  "keywords": [
    "nodejs",
    "express",
    "typescript",
    "starter",
    "backend",
    "api",
    "template"
  ],

  "author": "ByeMoon37",
  "license": "ISC",

  "packageManager": "pnpm@10.33.0",

  "dependencies": {
    "body-parser": "^2.2.2",
    "colorette": "^2.0.20",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "response-time": "^2.3.4",
    "rotating-file-stream": "^3.2.9"
  },

  "devDependencies": {
    "@eslint/js": "^10.0.1",

    "@types/body-parser": "^1.19.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/response-time": "^2.3.9",

    "eslint": "^10.4.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}